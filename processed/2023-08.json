      "message_id": "<CAPPM_gRfw3W3Pz4TW1ajsnechgS7TLG76HHjnJXTgsH779qniA@mail.gmail.com>",
      "from_name": "Joshua Ulrich",
      "from_email_hash": "23f6c30ff3bdcca471f7faac8696c097be744a921830fdf6ee417f06337a1b60",
      "date": "2023-08-12T12:38:46-05:00",
      "subject": "[R-SIG-Finance]  xts: Transfer/expand values to higher periodicity",
      "subject_clean": "xts: Transfer/expand values to higher periodicity",
      "in_reply_to": "<ZNaYYpCR_qGXvb4Z@local>",
